{
  "routes": [
    {
      "routePath": "/api/ai-news",
      "mountPath": "/api",
      "method": "",
      "module": [
        "api/ai-news.ts:onRequest"
      ]
    },
    {
      "routePath": "/article/:slug",
      "mountPath": "/article",
      "method": "",
      "module": [
        "article/[slug].ts:onRequest"
      ]
    },
    {
      "routePath": "/blog/:slug",
      "mountPath": "/blog",
      "method": "",
      "module": [
        "blog/[slug].ts:onRequest"
      ]
    },
    {
      "routePath": "/category/:slug",
      "mountPath": "/category",
      "method": "",
      "module": [
        "category/[slug].ts:onRequest"
      ]
    },
    {
      "routePath": "/:sitemap",
      "mountPath": "/",
      "method": "",
      "module": [
        "[sitemap].ts:onRequest"
      ]
    }
  ],
  "baseURL": "/"
}